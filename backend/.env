# =========================
# CONFIGURACIÓN BASE DE DATOS
# =========================

# Dirección del servidor de base de datos
DB_HOST=localhost

# Usuario de MySQL
DB_USER=booknotes_user

# Contraseña del usuario de MySQL
DB_PASSWORD=12345678

# Nombre de la base de datos
DB_NAME=booknotes

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# =========================
# CONFIGURACIÓN DEL BACKEND
# =========================

# Clave secreta para firmar los JWT
# NO subir a GitHub ni exponer en el frontend
JWT_SECRET=booknotes_secret

# Tiempo de expiración del token (opcional, formato soportado por jsonwebtoken)
# Ejemplo: 1h = 1 hora, 30m = 30 minutos
JWT_EXPIRES_IN=1h

# Puerto donde corre el backend Express
PORT=3000