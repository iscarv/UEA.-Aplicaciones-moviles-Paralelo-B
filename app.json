{
  "expo": {
    "name": "BookNotes",
    "slug": "BookNotes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/BookNotes.png",
    "scheme": "booknotes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Esta aplicación necesita acceso a la cámara para tomar fotos de la portada del libro."
      }
    },
    "android": {
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/BookNotes.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.BookNotes"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/BookNotes.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "La aplicación necesita acceso a la cámara para tomar la foto de la portada del libro."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/default.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "605e3a4b-f625-472c-bed0-c1c6292bc230"
      }
    }
  }
}
